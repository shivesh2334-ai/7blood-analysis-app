# LabIQ Configuration
# Copy this file to .env and customize as needed.

# AI model to use for clinical review (default: claude-sonnet-4-20250514)
LABIQ_AI_MODEL=claude-sonnet-4-20250514

# Maximum tokens for AI response (default: 2000)
LABIQ_AI_MAX_TOKENS=2000

# Default patient age (default: 35)
LABIQ_DEFAULT_AGE=35

# Default patient sex (default: male)
LABIQ_DEFAULT_SEX=male
